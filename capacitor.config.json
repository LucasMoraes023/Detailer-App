{
  "appId": "com.lucasmoraes.detailer",
  "appName": "Detailer Lucas Moraes",
  "webDir": "dist",
  "server": {
    "url": "http://localhost:5173",
    "cleartext": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#000000",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  }
}
